import matplotlib.pyplot as plt
import pandas as pd
import numpy as np

def generar_graficas():
    # 1. Carga los datos desde el CSV
    try:
        datos = pd.read_csv('resultados_tiempos.csv')
    except FileNotFoundError:
        print("Error: No se encontró 'resultados_tiempos.csv'. Ejecuta el Main primero.")
        return

    n = datos['N']
    tiempos = datos['Tiempo_Segundos']

    # Crea una figura con dos sub-gráficas (1 fila, 2 columnas)
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))

    # --- GRÁFICA 1: ESCALA LINEAL (Ver la parábola) ---
    ax1.plot(n, tiempos, 'o-', color='blue', label='Datos Reales')
    ax1.set_title('Complejidad Algorítmica: Gale-Shapley\n(Escala Lineal)')
    ax1.set_xlabel('Tamaño de la instancia (N)')
    ax1.set_ylabel('Tiempo de ejecución (segundos)')
    ax1.grid(True, linestyle='--', alpha=0.7)
    ax1.legend()

    # --- GRÁFICA 2: ESCALA LOGARÍTMICA (Confirmar O(N^2)) ---
    # En escala log-log, una función N^2 se ve como una línea recta
    ax2.loglog(n, tiempos, 'o-', color='red', label='Datos Reales (Log)')
    ax2.set_title('Análisis Asintótico\n(Escala Log-Log)')
    ax2.set_xlabel('Log(N)')
    ax2.set_ylabel('Log(Tiempo)')
    ax2.grid(True, which="both", ls="-", alpha=0.5)
    ax2.legend()

    # Ajustar diseño para que no se encimen los títulos
    plt.tight_layout()
    
    # Guardar la gráfica
    plt.savefig('analisis_complejidad.png', dpi=300)
    print("Gráfica guardada exitosamente como 'analisis_complejidad.png'")
    
    # Mostrar la gráfica en pantalla
    plt.show()

if __name__ == "__main__":
    generar_graficas()